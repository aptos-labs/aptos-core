//**** Cross-compiled for `move` syntax from `tests/no-v1-comparison/closures/closure_mask.move`

//# publish
module 0x42::test {
    fun if_then(p0: bool, p1: u64, p2: u64): u64 {
        if (p0) return p1;
        p2
    }
    public fun run(): bool {
        let _v0 = |x,y| if_then(true, x, y);
        let _v1 = |x,y| if_then(x, 10, y);
        let _v2 = |x| if_then(false, 10, x);
        let _v3 = |x,y| if_then(x, y, 20);
        assert!(_v0(3, 4) == 3, 14566554180833181696);
        assert!(_v1(true, 22222) == 10, 14566554180833181696);
        assert!(_v2(43) == 43, 14566554180833181696);
        assert!(_v3(false, 23333) == 20, 14566554180833181696);
        true
    }
}


