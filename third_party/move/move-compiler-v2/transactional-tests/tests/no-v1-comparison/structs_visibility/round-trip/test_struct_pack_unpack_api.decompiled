        assert!(*m3::borrow_0x42_m3_S_f_0<u64>(&_v1) == 43, 13);
        assert!(*m1::borrow_0x42_m1_T_h_0<u64>(m3::borrow_0x42_m3_S_g_1<u64>(&_v1)) == 42, 14);
