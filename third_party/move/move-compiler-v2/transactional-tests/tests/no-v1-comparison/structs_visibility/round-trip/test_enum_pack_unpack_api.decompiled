//# publish
module 0x42::m2 {
    use 0x42::m1;
    public fun test_pack_unpack_result_err() {
        assert!(m1::unpack_0x42_m1_Result_Err<u64,u8>(m1::pack_0x42_m1_Result_Err<u64,u8>(7u8)) == 7u8, 3);
    }
    public fun test_pack_unpack_result_ok() {
        let _v0 = m1::pack_0x42_m1_Result_Ok<u64,u64>(42);
        let _v1 = m1::pack_0x42_m1_Result_Ok<u64,u64>(42);
        assert!(_v0 == _v1, 1);
        assert!(m1::unpack_0x42_m1_Result_Ok<u64,u64>(_v0) == 42, 2);
    }
    public fun test_unpack_enum_e() {
        let _v0 = m1::pack_0x42_m1_E_A(100);
        let _v1 = m1::pack_0x42_m1_E_B(200);
        assert!(m1::unpack_0x42_m1_E_A(_v0) == 100, 4);
        assert!(m1::unpack_0x42_m1_E_B(_v1) == 200, 5);
    }
    public fun test_unpack_inner() {
        let _v0;
        let _v1;
        let _v2 = m1::pack_0x42_m1_Inner_Inner1(10);
        let _v3 = m1::pack_0x42_m1_Inner_Inner2(20, 30);
        let _v4 = &_v2;
        if (m1::test_variant_0x42_m1_Inner_Inner1(_v4)) _v1 = m1::unpack_0x42_m1_Inner_Inner1(_v2) else if (m1::test_variant_0x42_m1_Inner_Inner2(_v4)) {
            let (_v5,_v6) = m1::unpack_0x42_m1_Inner_Inner2(_v2);
            _v1 = _v5 + _v6
        } else abort 14566554180833181697;
        let _v7 = &_v3;
        if (m1::test_variant_0x42_m1_Inner_Inner1(_v7)) _v0 = m1::unpack_0x42_m1_Inner_Inner1(_v3) else if (m1::test_variant_0x42_m1_Inner_Inner2(_v7)) {
            let (_v8,_v9) = m1::unpack_0x42_m1_Inner_Inner2(_v3);
            _v0 = _v8 + _v9
        } else abort 14566554180833181697;
        assert!(_v1 == 10, 6);
        assert!(_v0 == 50, 7);
    }
}


