//# publish
module 0x42::m2 {
    use 0x42::m1;
    public fun try_nested_pair_unpack() {
        let _v0 = m1::pack_0x42_m1_Pair(5, false);
        let _v1 = m1::pack_0x42_m1_Wrapper<vector<u64>>(vector[42, 43]);
        let (_v2,_v3) = m1::unpack_0x42_m1_NestedPair<vector<u64>>(m1::pack_0x42_m1_NestedPair<vector<u64>>(_v0, _v1));
        let (_v4,_v5) = m1::unpack_0x42_m1_Pair(_v2);
        let _v6 = m1::unpack_0x42_m1_Wrapper<vector<u64>>(_v3);
        assert!(_v4 == 5, 4);
        assert!(_v5 == false, 5);
        assert!(*0x1::vector::borrow<u64>(&_v6, 1) == 43, 6);
    }
    public fun try_pack_unpack_pair() {
        let (_v0,_v1) = m1::unpack_0x42_m1_Pair(m1::pack_0x42_m1_Pair(1, true));
        assert!(_v0 == 1, 1);
        assert!(_v1 == true, 2);
    }
    public fun try_pack_unpack_wrapper() {
        assert!(m1::unpack_0x42_m1_Wrapper<u64>(m1::pack_0x42_m1_Wrapper<u64>(100)) == 100, 3);
    }
    public fun try_pass_as_arg() {
        use_as_param(m1::pack_0x42_m1_Pair(88, true));
    }
    public fun use_as_param(p0: m1::Pair) {
        let (_v0,_v1) = m1::unpack_0x42_m1_Pair(p0);
        assert!(_v0 == 88, 11);
        assert!(_v1 == true, 12);
    }
    public fun try_return_positional(): m1::Pair {
        m1::pack_0x42_m1_Pair(77, false)
    }
    public fun try_unpack_from_return() {
        let (_v0,_v1) = m1::unpack_0x42_m1_Pair(try_return_positional());
        assert!(_v0 == 77, 9);
        assert!(_v1 == false, 10);
    }
    public fun try_vecwrap_unpack() {
        let _v0 = m1::unpack_0x42_m1_VecWrap<u64>(m1::pack_0x42_m1_VecWrap<u64>(vector[10, 20, 30]));
        assert!(*0x1::vector::borrow<u64>(&_v0, 0) == 10, 7);
        assert!(*0x1::vector::borrow<u64>(&_v0, 2) == 30, 8);
    }
}


