//# publish
module 0x42::m2 {
    use 0x42::m1;
    public fun test_borrow_nested_pair_fields() {
        let _v0 = m1::pack_0x42_m1_Pair(1, false);
        let _v1 = m1::pack_0x42_m1_Wrapper<u64>(99);
        let _v2 = m1::pack_0x42_m1_NestedPair<u64>(_v0, _v1);
        let _v3 = m1::borrow_0x42_m1_Pair_0_0(m1::borrow_0x42_m1_NestedPair_0_0<u64>(&_v2));
        let _v4 = m1::borrow_0x42_m1_Pair_1_1(m1::borrow_0x42_m1_NestedPair_0_0<u64>(&_v2));
        let _v5 = m1::borrow_0x42_m1_Wrapper_0_0<u64>(m1::borrow_0x42_m1_NestedPair_1_1<u64>(&_v2));
        assert!(*_v3 == 1, 3);
        if (*_v4) abort 4;
        assert!(*_v5 == 99, 5);
    }
    public fun test_borrow_pair_fields() {
        let _v0 = m1::pack_0x42_m1_Pair(42, true);
        let _v1 = m1::borrow_0x42_m1_Pair_0_0(&_v0);
        let _v2 = m1::borrow_0x42_m1_Pair_1_1(&_v0);
        assert!(*_v1 == 42, 0);
        assert!(*_v2, 1);
    }
    public fun test_borrow_vecwrap_element() {
        let _v0 = m1::pack_0x42_m1_VecWrap<u64>(vector[10, 20, 30]);
        let _v1 = 0x1::vector::borrow<u64>(m1::borrow_0x42_m1_VecWrap_0_0<u64>(&_v0), 0);
        let _v2 = 0x1::vector::borrow<u64>(m1::borrow_0x42_m1_VecWrap_0_0<u64>(&_v0), 1);
        assert!(*_v1 == 10, 6);
        assert!(*_v2 == 20, 7);
    }
    public fun test_borrow_wrapper_field() {
        let _v0 = m1::pack_0x42_m1_Wrapper<u64>(100);
        assert!(*m1::borrow_0x42_m1_Wrapper_0_0<u64>(&_v0) == 100, 2);
    }
    public fun test_mut_borrow_nestedpair() {
        let _v0 = m1::pack_0x42_m1_Pair(0, true);
        let _v1 = m1::pack_0x42_m1_Wrapper<u64>(77);
        let _v2 = m1::pack_0x42_m1_NestedPair<u64>(_v0, _v1);
        let _v3 = &mut _v2;
        let _v4 = m1::borrow_mut_0x42_m1_Pair_0_0(m1::borrow_mut_0x42_m1_NestedPair_0_0<u64>(_v3));
        *_v4 = 123;
        _v4 = m1::borrow_mut_0x42_m1_Wrapper_0_0<u64>(m1::borrow_mut_0x42_m1_NestedPair_1_1<u64>(_v3));
        *_v4 = 456;
        assert!(*m1::borrow_0x42_m1_Pair_0_0(m1::borrow_0x42_m1_NestedPair_0_0<u64>(&_v2)) == 123, 10);
        assert!(*m1::borrow_0x42_m1_Wrapper_0_0<u64>(m1::borrow_0x42_m1_NestedPair_1_1<u64>(&_v2)) == 456, 11);
    }
    public fun test_mut_borrow_nestedpair_2() {
        let _v0 = m1::pack_0x42_m1_Pair(0, true);
        let _v1 = m1::pack_0x42_m1_Wrapper<u64>(77);
        let _v2 = m1::pack_0x42_m1_NestedPair<u64>(_v0, _v1);
        let _v3 = &mut _v2;
        let _v4 = m1::borrow_mut_0x42_m1_NestedPair_0_0<u64>(_v3);
        let _v5 = m1::borrow_mut_0x42_m1_NestedPair_1_1<u64>(_v3);
        let _v6 = m1::borrow_mut_0x42_m1_Pair_0_0(_v4);
        let _v7 = m1::borrow_mut_0x42_m1_Wrapper_0_0<u64>(_v5);
        *_v6 = 123;
        *_v7 = 456;
        assert!(*m1::borrow_0x42_m1_Pair_0_0(m1::borrow_0x42_m1_NestedPair_0_0<u64>(&_v2)) == 123, 10);
        assert!(*m1::borrow_0x42_m1_Wrapper_0_0<u64>(m1::borrow_0x42_m1_NestedPair_1_1<u64>(&_v2)) == 456, 11);
    }
    public fun test_mut_borrow_pair() {
        let _v0 = m1::pack_0x42_m1_Pair(7, false);
        let _v1 = m1::borrow_mut_0x42_m1_Pair_0_0(&mut _v0);
        *_v1 = 8;
        assert!(*m1::borrow_0x42_m1_Pair_0_0(&_v0) == 8, 8);
    }
    public fun test_mut_borrow_vecwrap_element() {
        let _v0 = m1::pack_0x42_m1_VecWrap<u64>(vector[1, 2, 3]);
        let _v1 = 0x1::vector::borrow_mut<u64>(m1::borrow_mut_0x42_m1_VecWrap_0_0<u64>(&mut _v0), 1);
        *_v1 = 10;
        assert!(*0x1::vector::borrow<u64>(m1::borrow_0x42_m1_VecWrap_0_0<u64>(&_v0), 1) == 10, 9);
    }
}


