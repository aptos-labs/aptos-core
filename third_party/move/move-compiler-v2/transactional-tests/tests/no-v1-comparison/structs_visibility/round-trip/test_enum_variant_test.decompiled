//# publish
module 0x42::m2 {
    use 0x42::m;
    public fun test_match_mut_borrow() {
        let _v0 = m::pack_0x42_m_Data2_V2(43, 44);
        let _v1 = &mut _v0;
        let _v2 = m::test_variant_0x42_m_Data2_V2(freeze(_v1));
        loop {
            if (_v2) {
                let _v3 = m::borrow_mut_0x42_m_Data2_y_0(_v1);
                let _v4 = m::borrow_mut_0x42_m_Data2_x_1(_v1);
                if (*_v3 == 43) {
                    let _v5;
                    *_v4 = 45;
                    let _v6 = &_v0;
                    if (m::test_variant_0x42_m_Data2_V2(_v6)) _v5 = m::borrow_0x42_m_Data2_x_1(_v6) else _v5 = m::borrow_0x42_m_Data2_x_0(_v6);
                    if (*_v5 == 45) break;
                    abort 1
                }
            };
            return ()
        };
    }
    fun test_v1(): bool {
        let _v0 = m::pack_0x42_m_Data_V1(43);
        if (m::test_variant_0x42_m_Data_V1(&_v0)) {
            let _v1 = &_v0;
            let _v2 = m::test_variant_0x42_m_Data_V1(_v1);
            let _v3 = _v2;
            loop {
                if (!_v3) {
                    _v2 = m::test_variant_0x42_m_Data_V3(_v1);
                    if (_v2) break
                };
                return _v2
            };
            return _v2
        };
        false
    }
    public fun test_v1_mut_borrow() {
        let _v0 = m::pack_0x42_m_Data_V1(43);
        let _v1 = m::borrow_mut_0x42_m_Data_x_0(&mut _v0);
        *_v1 = 44;
        assert!(*m::borrow_0x42_m_Data_x_0(&_v0) == 44, 1);
    }
    fun test_v1v3(): bool {
        let _v0 = m::pack_0x42_m_Data_V1(43);
        let _v1 = &_v0;
        let _v2 = m::test_variant_0x42_m_Data_V1(_v1);
        if (!_v2) _v2 = m::test_variant_0x42_m_Data_V3(_v1);
        let _v3 = m::pack_0x42_m_Data_V3();
        if (_v2) {
            let _v4 = &_v3;
            let _v5 = m::test_variant_0x42_m_Data_V1(_v4);
            let _v6 = _v5;
            loop {
                if (!_v6) {
                    _v5 = m::test_variant_0x42_m_Data_V3(_v4);
                    if (_v5) break
                };
                return _v5
            };
            return _v5
        };
        false
    }
    fun test_v1v3_ref(): bool {
        let _v0 = m::pack_0x42_m_Data_V1(43);
        let _v1 = &_v0;
        let _v2 = m::test_variant_0x42_m_Data_V1(_v1);
        if (!_v2) _v2 = m::test_variant_0x42_m_Data_V3(_v1);
        let _v3 = m::pack_0x42_m_Data_V3();
        if (_v2) {
            let _v4 = &mut _v3;
            let _v5 = m::test_variant_0x42_m_Data_V1(freeze(_v4));
            let _v6 = _v5;
            loop {
                if (!_v6) {
                    _v5 = m::test_variant_0x42_m_Data_V3(freeze(_v4));
                    if (_v5) break
                };
                return _v5
            };
            return _v5
        };
        false
    }
    public fun test_v2_mut_borrow_2() {
        let _v0;
        let _v1;
        let _v2 = m::pack_0x42_m_Data2_V2(43, 44);
        let _v3 = &mut _v2;
        if (m::test_variant_0x42_m_Data2_V2(freeze(_v3))) _v0 = m::borrow_mut_0x42_m_Data2_x_1(_v3) else _v0 = m::borrow_mut_0x42_m_Data2_x_0(_v3);
        *_v0 = 45;
        let _v4 = &_v2;
        if (m::test_variant_0x42_m_Data2_V2(_v4)) _v1 = m::borrow_0x42_m_Data2_x_1(_v4) else _v1 = m::borrow_0x42_m_Data2_x_0(_v4);
        assert!(*_v1 == 45, 1);
    }
}


