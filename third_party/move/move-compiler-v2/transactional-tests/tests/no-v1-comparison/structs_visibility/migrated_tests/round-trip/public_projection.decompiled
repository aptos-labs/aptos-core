//**** Cross-compiled for `move` syntax from `tests/no-v1-comparison/structs_visibility/migrated_tests/public_projection.move`

//# publish
module 0x42::test {
    struct T<T0, T1> has drop {
        x: T0,
        y: T1,
    }
    struct S<T0, T1, T2> has drop {
        _0: T0,
        _1: T1,
        _2: T2,
    }
    #[pack]
    public fun pack_0x42_test_T<T0, T1>(p0: T0, p1: T1): T<T0, T1> {
        T<T0,T1>{x: p0, y: p1}
    }
    #[unpack]
    public fun unpack_0x42_test_T<T0, T1>(p0: T<T0, T1>): (T0, T1) {
        let T<T0,T1>{x: _v0, y: _v1} = p0;
        (_v0, _v1)
    }
    #[borrow]
    public fun borrow_0x42_test_T_x_0<T0, T1>(p0: &T<T0, T1>): &T0 {
        &p0.x
    }
    #[borrow]
    public fun borrow_0x42_test_T_y_1<T0, T1>(p0: &T<T0, T1>): &T1 {
        &p0.y
    }
    #[borrow_mut]
    public fun borrow_mut_0x42_test_T_x_0<T0, T1>(p0: &mut T<T0, T1>): &mut T0 {
        &mut p0.x
    }
    #[borrow_mut]
    public fun borrow_mut_0x42_test_T_y_1<T0, T1>(p0: &mut T<T0, T1>): &mut T1 {
        &mut p0.y
    }
    #[pack]
    public fun pack_0x42_test_S<T0, T1, T2>(p0: T0, p1: T1, p2: T2): S<T0, T1, T2> {
        S<T0,T1,T2>{_0: p0, _1: p1, _2: p2}
    }
    #[unpack]
    public fun unpack_0x42_test_S<T0, T1, T2>(p0: S<T0, T1, T2>): (T0, T1, T2) {
        let S<T0,T1,T2>{_0: _v0, _1: _v1, _2: _v2} = p0;
        (_v0, _v1, _v2)
    }
    #[borrow]
    public fun borrow_0x42_test_S_0_0<T0, T1, T2>(p0: &S<T0, T1, T2>): &T0 {
        &p0._0
    }
    #[borrow]
    public fun borrow_0x42_test_S_1_1<T0, T1, T2>(p0: &S<T0, T1, T2>): &T1 {
        &p0._1
    }
    #[borrow]
    public fun borrow_0x42_test_S_2_2<T0, T1, T2>(p0: &S<T0, T1, T2>): &T2 {
        &p0._2
    }
    #[borrow_mut]
    public fun borrow_mut_0x42_test_S_0_0<T0, T1, T2>(p0: &mut S<T0, T1, T2>): &mut T0 {
        &mut p0._0
    }
    #[borrow_mut]
    public fun borrow_mut_0x42_test_S_1_1<T0, T1, T2>(p0: &mut S<T0, T1, T2>): &mut T1 {
        &mut p0._1
    }
    #[borrow_mut]
    public fun borrow_mut_0x42_test_S_2_2<T0, T1, T2>(p0: &mut S<T0, T1, T2>): &mut T2 {
        &mut p0._2
    }
}


//# publish
module 0x42::test_projection {
    use 0x42::test;
    fun get_x<T0, T1: drop>(p0: test::T<T0, T1>): T0 {
        let (_v0,_v1) = test::unpack_0x42_test_T<T0,T1>(p0);
        _v0
    }
    fun get_x_ref<T0, T1>(p0: &test::T<T0, T1>): &T0 {
        test::borrow_0x42_test_T_x_0<T0,T1>(p0)
    }
    fun proj_0<T0, T1: drop, T2: drop>(p0: test::S<T0, T1, T2>): T0 {
        let (_v0,_v1,_v2) = test::unpack_0x42_test_S<T0,T1,T2>(p0);
        _v0
    }
    fun proj_0_ref<T0, T1, T2>(p0: &test::S<T0, T1, T2>): &T0 {
        test::borrow_0x42_test_S_0_0<T0,T1,T2>(p0)
    }
    fun proj_2<T0: drop, T1: drop, T2>(p0: test::S<T0, T1, T2>): T2 {
        let (_v0,_v1,_v2) = test::unpack_0x42_test_S<T0,T1,T2>(p0);
        _v2
    }
    fun proj_2_ref<T0, T1, T2>(p0: &test::S<T0, T1, T2>): &T2 {
        test::borrow_0x42_test_S_2_2<T0,T1,T2>(p0)
    }
    fun test_get_x(): u8 {
        get_x<u8,bool>(test::pack_0x42_test_T<u8,bool>(42u8, true))
    }
    fun test_get_x_ref(): u8 {
        let _v0 = test::pack_0x42_test_T<u8,bool>(42u8, true);
        *get_x_ref<u8,bool>(&_v0)
    }
    fun test_proj_0(): u8 {
        proj_0<u8,address,bool>(test::pack_0x42_test_S<u8,address,bool>(42u8, @0x1, true))
    }
    fun test_proj_0_ref(): u8 {
        let _v0 = test::pack_0x42_test_S<u8,address,bool>(42u8, @0x1, true);
        *proj_0_ref<u8,address,bool>(&_v0)
    }
    fun test_proj_2(): bool {
        proj_2<u64,address,bool>(test::pack_0x42_test_S<u64,address,bool>(42, @0x1, true))
    }
    fun test_proj_2_ref(): bool {
        let _v0 = test::pack_0x42_test_S<u64,address,bool>(42, @0x1, true);
        *proj_2_ref<u64,address,bool>(&_v0)
    }
}


