//# publish
module 0x42::test_pack_unpack_ref {
    use 0x42::pack_unpack_ref;
    fun unpack_ref_G() {
        let _v0 = pack_unpack_ref::pack_0x42_pack_unpack_ref_S(0, 1);
        let _v1 = pack_unpack_ref::pack_0x42_pack_unpack_ref_G(2, 3, _v0);
        let _v2 = &mut _v1;
        let _v3 = pack_unpack_ref::borrow_mut_0x42_pack_unpack_ref_G_x1_0(_v2);
        let _v4 = pack_unpack_ref::borrow_mut_0x42_pack_unpack_ref_G_x2_1(_v2);
        let _v5 = pack_unpack_ref::borrow_mut_0x42_pack_unpack_ref_G_s_2(_v2);
        let _v6 = pack_unpack_ref::borrow_mut_0x42_pack_unpack_ref_S_f_0(_v5);
        let _v7 = pack_unpack_ref::borrow_mut_0x42_pack_unpack_ref_S_g_1(_v5);
        assert!(*_v6 == 0, 0);
        assert!(*_v7 == 1, 1);
        assert!(*_v3 == 2, 2);
        assert!(*_v4 == 3, 3);
        *_v3 = *_v3 + 1;
        *_v4 = *_v4 + 1;
        *_v6 = *_v6 + 1;
        *_v7 = *_v7 + 1;
        assert!(*_v6 == 1, 0);
        assert!(*_v7 == 2, 1);
        assert!(*_v3 == 3, 2);
        assert!(*_v4 == 4, 3);
    }
}


