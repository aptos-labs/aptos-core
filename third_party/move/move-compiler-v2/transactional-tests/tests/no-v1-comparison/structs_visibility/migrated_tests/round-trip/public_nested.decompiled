//# publish
module 0x42::test_nested {
    use 0x42::test;
    fun extract_first_u8(p0: &test::E): u8 {
        let _v0 = test::test_variant_0x42_test_E_V1(p0);
        loop {
            if (!_v0) {
                if (test::test_variant_0x42_test_E_V2(p0)) break;
                abort 14566554180833181697
            };
            return *test::borrow_0x42_test_E_0_0(p0)
        };
        *test::borrow_0x42_test_E_x_0(p0)
    }
    fun extract_last_u8(p0: &test::E): u8 {
        let _v0 = test::test_variant_0x42_test_E_V1(p0);
        loop {
            if (!_v0) {
                if (test::test_variant_0x42_test_E_V2(p0)) break;
                abort 14566554180833181697
            };
            return *test::borrow_0x42_test_S1_x_0<u8,bool>(test::borrow_0x42_test_E_1_1(p0))
        };
        *test::borrow_0x42_test_S0_0_0<u8,bool>(test::borrow_0x42_test_E_y_1(p0))
    }
    fun test1(): u8 {
        let _v0 = test::pack_0x42_test_S1<u8,bool>(43u8, true);
        let _v1 = test::pack_0x42_test_E_V1(42u8, _v0);
        extract_first_u8(&_v1)
    }
    fun test2(): u8 {
        let _v0 = test::pack_0x42_test_S0<u8,bool>(43u8, true);
        let _v1 = test::pack_0x42_test_E_V2(42u8, _v0);
        extract_first_u8(&_v1)
    }
    fun test3(): u8 {
        let _v0 = test::pack_0x42_test_S1<u8,bool>(43u8, true);
        let _v1 = test::pack_0x42_test_E_V1(42u8, _v0);
        extract_last_u8(&_v1)
    }
    fun test4(): u8 {
        let _v0 = test::pack_0x42_test_S0<u8,bool>(43u8, true);
        let _v1 = test::pack_0x42_test_E_V2(42u8, _v0);
        extract_last_u8(&_v1)
    }
}


