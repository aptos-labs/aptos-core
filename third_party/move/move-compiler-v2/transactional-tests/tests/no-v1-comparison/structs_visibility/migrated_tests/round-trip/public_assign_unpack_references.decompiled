//# publish
module 0x42::m {
    struct R has drop {
        s1: S,
        s2: S,
    }
    struct S has drop {
        f: u64,
    }
    #[pack]
    public fun pack_0x42_m_R(p0: S, p1: S): R {
        R{s1: p0, s2: p1}
    }
    #[unpack]
    public fun unpack_0x42_m_R(p0: R): (S, S) {
        let R{s1: _v0, s2: _v1} = p0;
        (_v0, _v1)
    }
    #[borrow]
    public fun borrow_0x42_m_R_s1_0(p0: &R): &S {
        &p0.s1
    }
    #[borrow]
    public fun borrow_0x42_m_R_s2_1(p0: &R): &S {
        &p0.s2
    }
    #[borrow_mut]
    public fun borrow_mut_0x42_m_R_s1_0(p0: &mut R): &mut S {
        &mut p0.s1
    }
    #[borrow_mut]
    public fun borrow_mut_0x42_m_R_s2_1(p0: &mut R): &mut S {
        &mut p0.s2
    }
    #[pack]
    public fun pack_0x42_m_S(p0: u64): S {
        S{f: p0}
    }
    #[unpack]
    public fun unpack_0x42_m_S(p0: S): u64 {
        let S{f: _v0} = p0;
        _v0
    }
    #[borrow]
    public fun borrow_0x42_m_S_f_0(p0: &S): &u64 {
        &p0.f
