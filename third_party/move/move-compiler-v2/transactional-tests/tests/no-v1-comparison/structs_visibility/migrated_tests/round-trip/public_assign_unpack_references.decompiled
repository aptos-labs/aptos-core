}


//# publish
module 0x42::m2 {
    use 0x42::m;
    fun t1() {
        let _v0 = m::pack_0x42_m_S(0);
        let _v1 = m::pack_0x42_m_S(1);
        let _v2 = m::pack_0x42_m_R(_v0, _v1);
        let _v3 = &_v2;
        let _v4 = m::borrow_0x42_m_R_s1_0(_v3);
        let _v5 = m::borrow_0x42_m_R_s2_1(_v3);
        assert!(*m::borrow_0x42_m_S_f_0(_v4) == 0, 0);
        assert!(*m::borrow_0x42_m_S_f_0(_v5) == 1, 1);
    }
    fun t2() {
        let _v0 = m::pack_0x42_m_S(0);
        let _v1 = m::pack_0x42_m_S(1);
        let _v2 = m::pack_0x42_m_R(_v0, _v1);
        let _v3 = &mut _v2;
        let _v4 = m::borrow_mut_0x42_m_R_s1_0(_v3);
        let _v5 = m::borrow_mut_0x42_m_R_s2_1(_v3);
        assert!(*m::borrow_mut_0x42_m_S_f_0(_v4) == 0, 0);
        assert!(*m::borrow_0x42_m_S_f_0(freeze(_v5)) == 1, 1);
        let _v6 = 5;
        let _v7 = &mut _v6;
        let _v8 = m::pack_0x42_m_S(0);
        _v5 = &mut _v8;
        assert!(*_v7 == 5, 0);
        assert!(*m::borrow_0x42_m_S_f_0(freeze(_v5)) == 0, 1);
    }
}


