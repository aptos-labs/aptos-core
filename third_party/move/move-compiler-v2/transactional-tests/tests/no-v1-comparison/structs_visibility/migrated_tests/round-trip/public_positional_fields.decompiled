//**** Cross-compiled for `move` syntax from `tests/no-v1-comparison/structs_visibility/migrated_tests/public_positional_fields.move`

//# publish
module 0x42::test {
    struct Tup<T0, T1> {
        _0: T0,
        _1: T1,
    }
    #[pack]
    public fun pack_0x42_test_Tup<T0, T1>(p0: T0, p1: T1): Tup<T0, T1> {
        Tup<T0,T1>{_0: p0, _1: p1}
    }
    #[unpack]
    public fun unpack_0x42_test_Tup<T0, T1>(p0: Tup<T0, T1>): (T0, T1) {
        let Tup<T0,T1>{_0: _v0, _1: _v1} = p0;
        (_v0, _v1)
    }
    #[borrow]
    public fun borrow_0x42_test_Tup_0_0<T0, T1>(p0: &Tup<T0, T1>): &T0 {
        &p0._0
    }
    #[borrow]
    public fun borrow_0x42_test_Tup_1_1<T0, T1>(p0: &Tup<T0, T1>): &T1 {
        &p0._1
    }
    #[borrow_mut]
    public fun borrow_mut_0x42_test_Tup_0_0<T0, T1>(p0: &mut Tup<T0, T1>): &mut T0 {
        &mut p0._0
    }
    #[borrow_mut]
    public fun borrow_mut_0x42_test_Tup_1_1<T0, T1>(p0: &mut Tup<T0, T1>): &mut T1 {
        &mut p0._1
    }
}


//# publish
module 0x42::test_positional_fields {
    use 0x42::test;
    fun baz(p0: u64, p1: u64): u64 {
        let (_v0,_v1) = test::unpack_0x42_test_Tup<u64,u64>(test::pack_0x42_test_Tup<u64,u64>(p0, p1));
        _v0 - _v1
    }
    fun test_ok() {
        assert!(baz(2, 1) == 1, 42);
    }
}


//# run --verbose -- 0x42::test_positional_fields::test_ok