module 0x42::test_m {
    use 0x42::m;
    fun test_get_x_v1(): u64 {
        let _v0;
        let _v1 = m::pack_0x42_m_Data_V1(43);
        let _v2 = &_v1;
        if (m::test_variant_0x42_m_Data_V2(_v2) || m::test_variant_0x42_m_Data_V3(_v2)) _v0 = m::borrow_0x42_m_Data_x_1(_v2) else _v0 = m::borrow_0x42_m_Data_x_0(_v2);
        *_v0
    }
    fun test_get_x_v2(): u64 {
        let _v0;
        let _v1 = m::pack_0x42_m_Data_V2(false, 43);
        let _v2 = &_v1;
        if (m::test_variant_0x42_m_Data_V2(_v2) || m::test_variant_0x42_m_Data_V3(_v2)) _v0 = m::borrow_0x42_m_Data_x_1(_v2) else _v0 = m::borrow_0x42_m_Data_x_0(_v2);
        *_v0
    }
    fun test_get_x_v3(): u64 {
        let _v0;
        let _v1 = m::pack_0x42_m_Data_V3(1u8, 43);
        let _v2 = &_v1;
        if (m::test_variant_0x42_m_Data_V2(_v2) || m::test_variant_0x42_m_Data_V3(_v2)) _v0 = m::borrow_0x42_m_Data_x_1(_v2) else _v0 = m::borrow_0x42_m_Data_x_0(_v2);
        *_v0
    }
    fun test_get_y_v1(): bool {
        let _v0 = m::pack_0x42_m_Data_V1(43);
        *m::borrow_0x42_m_Data_y_0(&_v0)
    }
    fun test_get_y_v2(): bool {
        let _v0 = m::pack_0x42_m_Data_V2(true, 43);
        *m::borrow_0x42_m_Data_y_0(&_v0)
    }
    fun test_get_y_v3(): bool {
