// -- Sourcified model before first bytecode pipeline
module 0xc0ffee::m {
    public fun test1(p: u8): u8 {
        let __disc = p;
        if (__disc == 0u8) 1u8 else if (__disc == 1u8) 2u8 else 3u8
    }
    public fun test2(p: vector<u8>): u8 {
        let __disc = p;
        if (__disc == vector[]) 0u8 else if (__disc == vector[222u8, 173u8, 190u8, 239u8]) 1u8 else 2u8
    }
    public fun test3(p: bool, q: bool, r: bool): u8 {
        let (__disc_0,__disc_1) = (p, q);
        if (__disc_0 == true && __disc_1 == true) 0u8 else if (__disc_0 == true && __disc_1 == false) 1u8 else if (__disc_0 == false && __disc_1 == true) 2u8 else if (__disc_0 == false && __disc_1 == false && r) 3u8 else 5u8
    }
}
