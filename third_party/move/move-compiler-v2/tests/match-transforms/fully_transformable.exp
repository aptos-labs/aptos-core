            if And(Eq(_$disc_0, true), Eq(_$disc_1, false)) {
              1
            } else {
              if And(Eq(_$disc_0, false), Eq(_$disc_1, true)) {
                2
              } else {
                if And(And(Eq(_$disc_0, false), Eq(_$disc_1, false)), r) {
