// -- Sourcified model before first bytecode pipeline
module 0x42::retained_no_copy_fun_param {
    fun caller(x: u64): u64 {
        twice(|x| lambda__1__caller(x), x) + twice_copy(|x| lambda__2__caller(x), x)
    }
    inline fun twice(f: |u64|u64, x: u64): u64 {
        f(f(x))
    }

    spec twice(f: |u64|u64, x: u64): u64 {
        pragma opaque = true;
        ensures exists m: u64: ensures_of<f>(x, m) && ensures_of<f>(m, result);
    }

    inline fun twice_copy(f: |u64|u64 has copy + drop, x: u64): u64 {
        f(f(x))
    }

    spec twice_copy(f: |u64|u64 has copy + drop, x: u64): u64 {
        pragma opaque = true;
        ensures exists m: u64: ensures_of<f>(x, m) && ensures_of<f>(m, result);
    }

    fun lambda__1__caller(y: u64): u64 {
        y + 1
    }
    fun lambda__2__caller(y: u64): u64 {
        y + 1
    }
}


