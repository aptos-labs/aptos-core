// -- Model dump before first bytecode pipeline
module 0x1::signer {
    private fun address_of(self: &signer): address {
        Deref(signer::borrow_address(self))
    }
    private native fun borrow_address(self: &signer): &address;
    private fun test_receiver_calls(s: signer) {
        signer::address_of(Borrow(Immutable)(s));
        signer::borrow_address(Borrow(Immutable)(s));
        Tuple()
    }
} // end 0x1::signer

// -- Sourcified model before first bytecode pipeline
module 0x1::signer {
    fun address_of(self: &signer): address {
        *borrow_address(self)
    }
    native fun borrow_address(self: &signer): &address;
    fun test_receiver_calls(s: signer) {
        address_of(&s);
        borrow_address(&s);
    }
}
