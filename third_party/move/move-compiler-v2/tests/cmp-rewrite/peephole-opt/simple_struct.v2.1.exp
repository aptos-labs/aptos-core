============ bytecode before first stackless bytecode pipeline ================

[variant baseline]
public fun m::eq1($t0: vector<u8>, $t1: vector<u8>): vector<u8> {
     var $t2: vector<u8>
     var $t3: bool
     var $t4: vector<u8>
  0: $t4 := infer($t0)
  1: $t3 := ==($t4, $t1)
  2: if ($t3) goto 3 else goto 6
  3: label L0
  4: $t2 := infer($t0)
  5: goto 8
  6: label L1
  7: $t2 := infer($t1)
  8: label L2
  9: return $t2
}


[variant baseline]
public fun m::eq2($t0: vector<u8>, $t1: vector<u8>): bool {
     var $t2: bool
     var $t3: bool
     var $t4: vector<u8>
