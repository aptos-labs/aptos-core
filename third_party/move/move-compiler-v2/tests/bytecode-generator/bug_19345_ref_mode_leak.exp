// -- Model dump before first bytecode pipeline
module 0xc0ffee::m {
    struct Inner {
        x: u64,
    }
    struct Outer {
        inner: Inner,
    }
    private fun test_block_select(o: Outer): u64 {
        select m::Inner.x<Inner>(select m::Outer.inner<Outer>(o))
    }
    private fun test_block_with_side_effect(o: Outer): u64 {
        select m::Inner.x<Inner>({
          let _y: u64 = 1;
          select m::Outer.inner<Outer>(o)
        })
    }
    private fun test_if_else_select(cond: bool,o1: Outer,o2: Outer): u64 {
        select m::Inner.x<Inner>(if cond {
          select m::Outer.inner<Outer>(o1)
        } else {
          select m::Outer.inner<Outer>(o2)
        })
    }
    private fun test_mutate_if_else(cond: bool,o1: Outer,o2: Outer): Outer {
        {
          let result: Outer = if cond {
            o1
          } else {
            o2
          };
          select m::Inner.x<Inner>(select m::Outer.inner<Outer>(result)) = 42;
          result
        }
    }
} // end 0xc0ffee::m

// -- Sourcified model before first bytecode pipeline
module 0xc0ffee::m {
    struct Inner has copy, drop {
        x: u64,
    }
    struct Outer has copy, drop {
        inner: Inner,
    }
    fun test_block_select(o: Outer): u64 {
        o.inner.x
    }
    fun test_block_with_side_effect(o: Outer): u64 {
        {
            let _y = 1;
            o.inner
        }.x
    }
    fun test_if_else_select(cond: bool, o1: Outer, o2: Outer): u64 {
        (if (cond) o1.inner else o2.inner).x
    }
    fun test_mutate_if_else(cond: bool, o1: Outer, o2: Outer): Outer {
        let result = if (cond) o1 else o2;
        result.inner.x = 42;
        result
    }
}

