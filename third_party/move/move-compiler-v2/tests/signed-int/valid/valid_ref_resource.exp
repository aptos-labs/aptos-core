module 0x42::valid_ref_resource {
    use std::signer;
    struct S1 has copy, drop, key {
        x: u64,
        y: 0x1::i64::I64,
        z: 0x1::i128::I128,
    }
    fun test_borrow1(a: 0x1::i64::I64): &0x1::i64::I64 {
        &a
    }
    fun test_borrow2(a: 0x1::i128::I128): &0x1::i128::I128 {
        &a
    }
    fun test_deref1(a: &0x1::i64::I64): 0x1::i64::I64 {
        *a
    }
    fun test_deref2(a: &0x1::i128::I128): 0x1::i128::I128 {
        *a
    }
    fun test_exist1(addr: address): 0x1::i64::I64 {
        if (exists<S1>(addr)) {
            let s = borrow_global<S1>(addr);
            s.y
        } else 0x1::i64::pack(1)
    }
    fun test_exist2(addr: address): 0x1::i128::I128 {
        if (exists<S1>(addr)) {
            let s = borrow_global<S1>(addr);
            s.z
        } else 0x1::i128::pack(1u128)
    }
    fun test_move_from(account: &signer, addr: address): 0x1::i64::I64 {
        let s1 = S1{x: 1, y: 0x1::i64::pack(-1), z: 0x1::i128::pack(-2u128)};
        if (exists<S1>(addr)) move_from<S1>(0x1::signer::address_of(account)).y else s1.y
    }
    fun test_move_to(account: &signer, addr: address) {
        let s1 = S1{x: 1, y: 0x1::i64::pack(-1), z: 0x1::i128::pack(-2u128)};
        if (!exists<S1>(addr)) move_to<S1>(s1, account)
    }
}

