// -- Model dump before first bytecode pipeline
module 0x42::valid_ref_resource {
    use std::signer;
    struct S1 {
        x: u64,
        y: 0x1::i64::I64,
        z: 0x1::i128::I128,
    }
    private fun test_borrow1(a: 0x1::i64::I64): &0x1::i64::I64 {
        Borrow(Immutable)(a)
    }
    private fun test_borrow2(a: 0x1::i128::I128): &0x1::i128::I128 {
        Borrow(Immutable)(a)
    }
    private fun test_deref1(a: &0x1::i64::I64): 0x1::i64::I64 {
        Deref(a)
    }
    private fun test_deref2(a: &0x1::i128::I128): 0x1::i128::I128 {
        Deref(a)
    }
    private fun test_exist1(addr: address): 0x1::i64::I64 {
        if exists<S1>(addr) {
          {
            let s: &S1 = BorrowGlobal(Immutable)<S1>(addr);
            select valid_ref_resource::S1.y<&S1>(s)
          }
        } else {
          i64::pack(1)
        }
    }
    private fun test_exist2(addr: address): 0x1::i128::I128 {
        if exists<S1>(addr) {
          {
            let s: &S1 = BorrowGlobal(Immutable)<S1>(addr);
            select valid_ref_resource::S1.z<&S1>(s)
          }
        } else {
          i128::pack(1)
        }
    }
    private fun test_move_from(account: &signer,addr: address): 0x1::i64::I64 {
        {
          let s1: S1 = pack valid_ref_resource::S1(1, i64::pack(-1), i128::pack(-2));
          if exists<S1>(addr) {
            select valid_ref_resource::S1.y<S1>(MoveFrom<S1>(signer::address_of(account)))
          } else {
            select valid_ref_resource::S1.y<S1>(s1)
          }
        }
    }
    private fun test_move_to(account: &signer,addr: address) {
        {
          let s1: S1 = pack valid_ref_resource::S1(1, i64::pack(-1), i128::pack(-2));
          if Not(exists<S1>(addr)) {
            MoveTo<S1>(account, s1)
          } else {
            Tuple()
          }
        }
    }
} // end 0x42::valid_ref_resource

