// -- Model dump before first bytecode pipeline
module 0x42::Test {
    public fun apply(f: |u64, u64|u64,x: u64,y: u64): u64 {
        (f)(x, y)
    }
    public fun test(): u64 {
        Test::apply(closure#0Test::__lambda__1__test(), 1, Test::apply(closure#0Test::__lambda__2__test(), 2, 1))
    }
    private fun __lambda__1__test(x: u64,y: u64): u64 {
        Add<u64>(x, y)
    }
    private fun __lambda__2__test(x: u64,y: u64): u64 {
        Mul<u64>(x, y)
    }
} // end 0x42::Test

// -- Sourcified model before first bytecode pipeline
module 0x42::Test {
    public fun apply(f: |u64, u64|u64, x: u64, y: u64): u64 {
        f(x, y)
    }
    public fun test(): u64 {
        apply(|x,y| lambda__1__test(x, y), 1, apply(|x,y| lambda__2__test(x, y), 2, 1))
    }
    fun lambda__1__test(x: u64, y: u64): u64 {
        x + y
    }
    fun lambda__2__test(x: u64, y: u64): u64 {
        x * y
    }
}
