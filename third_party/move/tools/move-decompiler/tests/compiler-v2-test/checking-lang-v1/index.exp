module 0x42::test {
    struct R has drop, key {
        value: bool,
    }
    struct X<M> has copy, drop, store {
        value: M,
    }
    struct Y<T> has drop, key {
        field: T,
    }
    fun init(s: &signer) {
        move_to<R>(s, R{value: true});
    }
    fun init_2(s: &signer) {
        move_to<Y<X<bool>>>(s, Y<X<bool>>{field: X<bool>{value: true}});
    }
    fun test_resource_1() {
        let _t0 = @0x1;
        if (!(*&borrow_global<R>(_t0).value == true)) abort 0;
    }
    fun test_resource_2() {
        let _t0 = false;
        let _t1 = @0x1;
        *&mut borrow_global_mut<R>(_t1).value = _t0;
        let _t4 = @0x1;
        if (!(*&borrow_global<R>(_t4).value == false)) abort 1;
    }
    fun test_resource_3() {
        let _t0 = @0x1;
        if (!(*&(&borrow_global<Y<X<bool>>>(_t0).field).value == true)) abort 0;
    }
    fun test_resource_4() {
        let _t1 = @0x1;
        *&mut (&mut borrow_global_mut<Y<X<bool>>>(_t1).field).value = false;
        let _t7 = @0x1;
        if (!(*&(&borrow_global<Y<X<bool>>>(_t7).field).value == false)) abort 1;
    }
    fun test_vector() {
        let _t0 = X<u64>{value: 2};
        let _t6 = 0x1::vector::empty<X<u64>>();
        let _t7 = &mut _t6;
        0x1::vector::push_back<X<u64>>(_t7, _t0);
        0x1::vector::push_back<X<u64>>(_t7, _t0);
        let _t8 = &_t6;
        let _t9 = 0;
        let _t10 = 0x1::vector::borrow<X<u64>>(_t8, _t9);
        if (!(*&_t10.value == 2)) abort 0;
    }
    fun test_vector_borrow() {
        let _t11 = 0x1::vector::empty<Y<X<bool>>>();
        let _t12 = &mut _t11;
        0x1::vector::push_back<Y<X<bool>>>(_t12, Y<X<bool>>{field: X<bool>{value: true}});
        0x1::vector::push_back<Y<X<bool>>>(_t12, Y<X<bool>>{field: X<bool>{value: false}});
        let _t3 = _t11;
        let _t13 = &_t3;
        let _t14 = 0;
        let _t15 = 0x1::vector::borrow<Y<X<bool>>>(_t13, _t14);
        if (!(*&(&_t15.field).value == true)) abort 0;
        let _t21 = &_t3;
        let _t22 = 1;
        let _t23 = 0x1::vector::borrow<Y<X<bool>>>(_t21, _t22);
        if (!(*&(&_t23.field).value == false)) abort 0;
    }
    fun test_vector_borrow_mut() {
        let _t11 = 0x1::vector::empty<Y<X<bool>>>();
        let _t12 = &mut _t11;
        0x1::vector::push_back<Y<X<bool>>>(_t12, Y<X<bool>>{field: X<bool>{value: true}});
        0x1::vector::push_back<Y<X<bool>>>(_t12, Y<X<bool>>{field: X<bool>{value: false}});
        let _t3 = _t11;
        let _t13 = &_t3;
        let _t14 = 0;
        let _t15 = 0x1::vector::borrow<Y<X<bool>>>(_t13, _t14);
        if (!(*&(&_t15.field).value == true)) abort 0;
        let _t21 = &_t3;
        let _t22 = 1;
        let _t23 = 0x1::vector::borrow<Y<X<bool>>>(_t21, _t22);
        if (!(*&(&_t23.field).value == false)) abort 0;
        let _t29 = false;
        let _t30 = &mut _t3;
        let _t31 = 0;
        let _t32 = 0x1::vector::borrow_mut<Y<X<bool>>>(_t30, _t31);
        *&mut (&mut _t32.field).value = _t29;
        let _t35 = true;
        let _t36 = &mut _t3;
        let _t37 = 1;
        let _t38 = 0x1::vector::borrow_mut<Y<X<bool>>>(_t36, _t37);
        *&mut (&mut _t38.field).value = _t35;
        let _t41 = &_t3;
        let _t42 = 0;
        let _t43 = 0x1::vector::borrow<Y<X<bool>>>(_t41, _t42);
        if (!(*&(&_t43.field).value == false)) abort 0;
        let _t49 = &_t3;
        let _t50 = 1;
        let _t51 = 0x1::vector::borrow<Y<X<bool>>>(_t49, _t50);
        if (!(*&(&_t51.field).value == true)) abort 0;
    }
