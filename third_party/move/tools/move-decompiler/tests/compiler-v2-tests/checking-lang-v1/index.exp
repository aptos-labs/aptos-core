module 0x42::test {
    struct R has drop, key {
        value: bool,
    }
    struct X<M> has copy, drop, store {
        value: M,
    }
    struct Y<T> has drop, key {
        field: T,
    }
    fun init(s: &signer) {
        move_to<R>(s, R{value: true});
    }
    fun init_2(s: &signer) {
        move_to<Y<X<bool>>>(s, Y<X<bool>>{field: X<bool>{value: true}});
    }
    fun test_resource_1() {
        let _t1 = borrow_global<R>(@0x1);
        if (!(*&_t1.value == true)) abort 0;
    }
    fun test_resource_2() {
        let _t2 = borrow_global_mut<R>(@0x1);
        *&mut _t2.value = false;
        let _t5 = borrow_global<R>(@0x1);
        if (!(*&_t5.value == false)) abort 1;
    }
    fun test_resource_3() {
        let _t1 = borrow_global<Y<X<bool>>>(@0x1);
        if (!(*&(&_t1.field).value == true)) abort 0;
    }
    fun test_resource_4() {
        let _t2 = borrow_global_mut<Y<X<bool>>>(@0x1);
        *&mut (&mut _t2.field).value = false;
        let _t8 = borrow_global<Y<X<bool>>>(@0x1);
        if (!(*&(&_t8.field).value == false)) abort 1;
    }
    fun test_vector() {
        let _t0 = X<u64>{value: 2};
        let _t6 = 0x1::vector::empty<X<u64>>();
        let _t7 = &mut _t6;
        0x1::vector::push_back<X<u64>>(_t7, _t0);
        0x1::vector::push_back<X<u64>>(_t7, _t0);
        let _t10 = 0x1::vector::borrow<X<u64>>(&_t6, 0);
        if (!(*&_t10.value == 2)) abort 0;
    }
    fun test_vector_borrow() {
        let _t11 = 0x1::vector::empty<Y<X<bool>>>();
        let _t12 = &mut _t11;
        0x1::vector::push_back<Y<X<bool>>>(_t12, Y<X<bool>>{field: X<bool>{value: true}});
        0x1::vector::push_back<Y<X<bool>>>(_t12, Y<X<bool>>{field: X<bool>{value: false}});
        let _t3 = _t11;
        let _t15 = 0x1::vector::borrow<Y<X<bool>>>(&_t3, 0);
        if (!(*&(&_t15.field).value == true)) abort 0;
        let _t23 = 0x1::vector::borrow<Y<X<bool>>>(&_t3, 1);
        if (!(*&(&_t23.field).value == false)) abort 0;
    }
    fun test_vector_borrow_mut() {
        let _t11 = 0x1::vector::empty<Y<X<bool>>>();
        let _t12 = &mut _t11;
        0x1::vector::push_back<Y<X<bool>>>(_t12, Y<X<bool>>{field: X<bool>{value: true}});
        0x1::vector::push_back<Y<X<bool>>>(_t12, Y<X<bool>>{field: X<bool>{value: false}});
        let _t3 = _t11;
        let _t15 = 0x1::vector::borrow<Y<X<bool>>>(&_t3, 0);
        if (!(*&(&_t15.field).value == true)) abort 0;
        let _t23 = 0x1::vector::borrow<Y<X<bool>>>(&_t3, 1);
        if (!(*&(&_t23.field).value == false)) abort 0;
        let _t32 = 0x1::vector::borrow_mut<Y<X<bool>>>(&mut _t3, 0);
        *&mut (&mut _t32.field).value = false;
        let _t38 = 0x1::vector::borrow_mut<Y<X<bool>>>(&mut _t3, 1);
        *&mut (&mut _t38.field).value = true;
        let _t43 = 0x1::vector::borrow<Y<X<bool>>>(&_t3, 0);
        if (!(*&(&_t43.field).value == false)) abort 0;
        let _t51 = 0x1::vector::borrow<Y<X<bool>>>(&_t3, 1);
        if (!(*&(&_t51.field).value == true)) abort 0;
    }
}

