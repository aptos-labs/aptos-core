module 0x42::loops {
    fun nested_loop(x: u64): u64 {
        while (x > 0) {
            if (x > 10) x = x - 1;
            x = x - 1;
        };
        x
    }
    fun while_loop(x: u64): u64 {
        while (x > 0) x = x - 1;
        x
    }
    fun while_loop_with_break_and_continue(x: u64): u64 {
        while (!(!(x > 0) || x == 42)) {
            if (x == 21) continue;
            x = x - 1;
        };
        x
    }
}

