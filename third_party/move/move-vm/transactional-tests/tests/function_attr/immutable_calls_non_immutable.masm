//# publish
// Invalid: an #[immutable] function calls a same-module non-immutable, non-native callee.
module 0x66::test_immutable_call

// A same-module non-immutable helper.
fun non_immutable_helper(): u64
    ld_u64 42
    ret

#[immutable] public fun call_non_immutable(): u64
    call non_immutable_helper
    ret

