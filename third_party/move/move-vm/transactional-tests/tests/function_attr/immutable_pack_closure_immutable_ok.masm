//# publish
// Valid: an #[immutable] function may capture another #[immutable] function via PackClosure.
module 0x66::test_immutable_pack_closure_ok

#[immutable] fun immutable_fn(x: u64): u64
    move_loc x
    ret

#[immutable] public fun capture_immutable(): |u64|u64
    pack_closure immutable_fn, 0
    ret

