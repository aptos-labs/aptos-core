//# publish
module 0x66::helper

// An immutable helper: calling this from another #[immutable] function is valid.
#[persistent, immutable] public fun helper_value(): u64
    ld_u64 42
    ret


//# publish
// Valid: an #[immutable] function may call another #[immutable] function.
module 0x66::test_immutable_call_ok
use 0x66::helper

#[persistent, immutable] public fun call_immutable(): u64
    call helper::helper_value
    ret

