//# publish
// Invalid: an #[immutable] function captures a non-immutable function via PackClosure.
module 0x66::test_immutable_pack_closure

fun non_immutable(x: u64): u64
    move_loc x
    ret

#[persistent, immutable] public fun capture_non_immutable(): |u64|u64
    pack_closure non_immutable, 0
    ret
