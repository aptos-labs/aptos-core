//# publish --print-bytecode
module 0x66::test_generic_borrow_swapped_type_params

struct Pair<A, B>
    first: A
    second: B

// Invalid: borrow$Pair$0 takes &Pair<T1, T0> — the signature has non-canonical type
// params. The bytecode is correct (borrow_field Pair<T0, T1>); only the declared param is wrong.
#[borrow(0)] public fun borrow$Pair$0<A, B>(l0: &Pair<B, A>): &A
    move_loc l0
    borrow_field Pair<A, B>, first
    ret
