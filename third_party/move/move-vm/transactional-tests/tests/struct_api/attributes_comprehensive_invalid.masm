//# publish --print-bytecode
module 0x66::test_attributes

struct S
    x: u64
    y: u64

// Test simple attributes without parameters
#[module_lock] public fun test_module_lock(): u8
    ld_u8 1
    ret

#[persistent] fun test_persistent(): u8
    ld_u8 2
    ret

// Test pack/unpack attributes with proper naming and return types
#[pack] public fun pack$S(l0: u64, l1: u64): S
    move_loc l0
    move_loc l1
    pack S
    ret

// Invalid: unpack returns only one field value, but struct S has two fields
#[unpack] public fun unpack$S(l0: S): u64
    move_loc l0
    unpack S
    pop
    ret

// Test borrow field attributes with u16 parameters
#[borrow=0] public fun borrow$S$0(l0: &S): &u64
    move_loc l0
    borrow_field S, x
    ret

#[borrow=1] public fun borrow$S$1(l0: &S): &u64
    move_loc l0
    borrow_field S, y
    ret

#[borrow_mut=0] public fun borrow_mut$S$0(l0: &mut S): &mut u64
    move_loc l0
    mut_borrow_field S, x
    ret

#[borrow_mut=1] public fun borrow_mut$S$1(l0: &mut S): &mut u64
    move_loc l0
    mut_borrow_field S, y
    ret
