module 0x66::test

// Regression: blocks producing different types at the same VID position
// must get distinct physical registers, not cross-type reuse.

fun vid_type_mismatch(x: u64): u64
    copy_loc x
    ld_u64 10
    gt
    br_false l1
    copy_loc x
    ret
l1: copy_loc x
    ld_u64 1
    add
    ret
