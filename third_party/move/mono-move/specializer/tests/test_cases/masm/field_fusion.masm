module 0x66::field_fusion

// Helper callee
fun identity(x: u64): u64
    move_loc x
    ret

struct Pair has drop+copy
  _1: u64
  _2: u64

// ---------------------------------------------------------------------------
// 1. Two field reads from the same struct, added together.
//    Pre-alloc fusion eliminates two borrow-ref temps, reducing register
//    pressure for the allocator.
// ---------------------------------------------------------------------------
fun add_two_fields(p: Pair): u64
    borrow_loc p
    borrow_field Pair, _1
    read_ref
    borrow_loc p
    borrow_field Pair, _2
    read_ref
    add
    ret

// ---------------------------------------------------------------------------
// 2. Field read result passed to a call.
//    The borrow temp competes with the call's arg area.
// ---------------------------------------------------------------------------
fun field_to_call(p: Pair): u64
    borrow_loc p
    borrow_field Pair, _1
    read_ref
    call identity
    ret

// ---------------------------------------------------------------------------
// 3. Two field reads feeding a two-arg call.
//    Both borrow temps waste register slots visible to the allocator.
// ---------------------------------------------------------------------------
fun two_fields_to_call(a: Pair, b: Pair): u64
    borrow_loc a
    borrow_field Pair, _1
    read_ref
    borrow_loc b
    borrow_field Pair, _2
    read_ref
    add
    call identity
    ret

// ---------------------------------------------------------------------------
// 4. Field read combined with arithmetic.
//    The borrow temp extends the live range of the struct reference
//    unnecessarily.
// ---------------------------------------------------------------------------
fun field_plus_constant(p: Pair): u64
    borrow_loc p
    borrow_field Pair, _1
    read_ref
    ld_u64 42
    add
    ret

// ---------------------------------------------------------------------------
// 5. Chain: read field, compute, write back to another field.
//    Both ImmBorrowField+ReadRef and MutBorrowField+WriteRef patterns
//    should fuse, eliminating two borrow temps.
// ---------------------------------------------------------------------------
fun increment_field(p: &mut Pair)
    copy_loc p
    borrow_field Pair, _1
    read_ref
    ld_u64 1
    add
    move_loc p
    mut_borrow_field Pair, _1
    write_ref
    ret
