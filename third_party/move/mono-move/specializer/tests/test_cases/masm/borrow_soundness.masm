module 0x66::borrow_soundness

// BorrowLoc source must NOT be substituted.
// copy_loc x -> st_loc y creates subst {y -> x}, but borrow_loc y
// must stay as y — substituting x would change the referenced slot.
fun borrow_loc_no_source_subst(x: u64): u64
    local y: u64
    copy_loc x
    st_loc y
    borrow_loc y
    read_ref
    ret

// Value uses of y CAN be propagated through the copy.
// The borrow_loc source is protected, but move_loc y is a value use.
fun imm_borrow_value_prop(x: u64): u64
    local y: u64
    copy_loc x
    st_loc y
    borrow_loc y
    read_ref
    move_loc y
    add
    ret

// MutBorrowLoc must kill the subst for the borrowed register.
// After write_ref, y holds 42 (not x's value), so move_loc y must
// read from y, not be substituted with x.
fun mut_borrow_kills_subst(x: u64): u64
    local y: u64
    copy_loc x
    st_loc y
    ld_u64 42
    mut_borrow_loc y
    write_ref
    move_loc y
    ret

// Reverse direction: subst {tmp -> y} must be killed when y is
// mutably borrowed, because y's value may change through the ref.
fun mut_borrow_kills_reverse(y: u64): u64
    local tmp: u64
    copy_loc y
    st_loc tmp
    ld_u64 99
    mut_borrow_loc y
    write_ref
    move_loc tmp
    ret
