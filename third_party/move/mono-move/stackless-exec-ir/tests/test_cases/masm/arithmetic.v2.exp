=== Module 0x66::test ===

fun add_values(r0, r1) {
    params: 2, locals: 0, registers: 3
    0: r2 := add r0, r1
    1: ret [r2]
}

fun complex_arith(r0) {
    params: 1, locals: 1, registers: 4
    0: r2 := ld_u64 2
    1: r1 := mul r0, r2
    2: r2 := ld_u64 1
    3: r3 := add r1, r2
    4: ret [r3]
}
