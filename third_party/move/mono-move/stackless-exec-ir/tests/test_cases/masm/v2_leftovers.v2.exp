=== Module 0x66::v2_leftovers ===

fun identity(r0) {
    params: 1, locals: 0, registers: 1
    0: ret [r0]
}

fun add_two(r0, r1) {
    params: 2, locals: 0, registers: 3
    0: r2 := add r0, r1
    1: ret [r2]
}

fun copy_to_call(r0) {
    params: 1, locals: 0, registers: 1, arg_regs: 1
    0: [a0] := call identity, [r0]
    1: ret [a0]
}

fun move_to_call(r0) {
    params: 1, locals: 0, registers: 1, arg_regs: 1
    0: [a0] := call identity, [r0]
    1: ret [a0]
}

fun multi_use_local_alias(r0) {
    params: 1, locals: 1, registers: 3
    0: r1 := add r0, #1
    1: r2 := add r1, r0
    2: ret [r2]
}

fun copy_call_then_use(r0) {
    params: 1, locals: 1, registers: 2, arg_regs: 1
    0: [a0] := call identity, [r0]
    1: r1 := add a0, r0
    2: ret [r1]
}

fun two_copies_to_call(r0, r1) {
    params: 2, locals: 0, registers: 2, arg_regs: 2
    0: [a0] := call add_two, [r0, r1]
    1: ret [a0]
}
