module 0x66::v2_leftovers

// Helper callees
fun identity(x: u64): u64
    move_loc x
    ret

fun add_two(a: u64, b: u64): u64
    copy_loc a
    copy_loc b
    add
    ret

// 1. Local copy that only feeds a call.
//    v1 copy propagation should be able to substitute the call operand.
fun copy_to_call(x: u64): u64
    copy_loc x
    call identity
    ret

// 2. MoveLoc that only feeds a call.
//    This isolates move-style forwarding from a pinned local.
fun move_to_call(x: u64): u64
    move_loc x
    call identity
    ret

// 3. A copied local value used more than once.
//    v2's current single-use-oriented local coalescing is likely to miss this.
fun multi_use_local_alias(x: u64): u64
    local tmp: u64
    copy_loc x
    st_loc tmp
    copy_loc tmp
    ld_u64 1
    add
    move_loc tmp
    add
    ret

// 4. Copy feeding a call argument and then another use.
//    This should leave the call-side alias visible if propagation is missing.
fun copy_call_then_use(x: u64): u64
    local y: u64
    copy_loc x
    st_loc y
    copy_loc y
    call identity
    move_loc y
    add
    ret

// 5. Two copied locals feeding a call.
//    This is a compact multi-arg version of the same issue.
fun two_copies_to_call(x: u64, y: u64): u64
    copy_loc x
    copy_loc y
    call add_two
    ret
