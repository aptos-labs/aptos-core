module 0x66::test

fun three_rets(): (u64, u64, u64)
    ld_u64 1
    ld_u64 2
    ld_u64 3
    ret

fun three_args(_a: &mut u64, _b: u64, _c: u64)
    ret

fun caller(x: &mut u64)
    local loc_a: u64
    local loc_c: u64
    call three_rets
    st_loc loc_c
    pop
    st_loc loc_a
    move_loc x
    move_loc loc_a
    ld_u64 0
    call three_args
    ret
