module 0x66::test

// --- Arithmetic across all 11 unspecialized widths ---

fun add_u8(a: u8, b: u8): u8
    copy_loc a
    copy_loc b
    add
    ret

fun sub_u16(a: u16, b: u16): u16
    copy_loc a
    copy_loc b
    sub
    ret

fun mul_u32(a: u32, b: u32): u32
    copy_loc a
    copy_loc b
    mul
    ret

fun div_u128(a: u128, b: u128): u128
    copy_loc a
    copy_loc b
    div
    ret

fun mod_u256(a: u256, b: u256): u256
    copy_loc a
    copy_loc b
    mod
    ret

fun add_i8(a: i8, b: i8): i8
    copy_loc a
    copy_loc b
    add
    ret

fun sub_i16(a: i16, b: i16): i16
    copy_loc a
    copy_loc b
    sub
    ret

fun mul_i32(a: i32, b: i32): i32
    copy_loc a
    copy_loc b
    mul
    ret

fun div_i64(a: i64, b: i64): i64
    copy_loc a
    copy_loc b
    div
    ret

fun mod_i128(a: i128, b: i128): i128
    copy_loc a
    copy_loc b
    mod
    ret

fun add_i256(a: i256, b: i256): i256
    copy_loc a
    copy_loc b
    add
    ret

// --- Bitwise (unsigned only) ---

fun bit_and_u128(a: u128, b: u128): u128
    copy_loc a
    copy_loc b
    bit_and
    ret

fun bit_or_u8(a: u8, b: u8): u8
    copy_loc a
    copy_loc b
    bit_or
    ret

fun bit_xor_u32(a: u32, b: u32): u32
    copy_loc a
    copy_loc b
    xor
    ret

// --- Shift (unsigned only; rhs is always u8) ---

fun shl_u16(a: u16, s: u8): u16
    copy_loc a
    copy_loc s
    shl
    ret

fun shr_u256(a: u256, s: u8): u256
    copy_loc a
    copy_loc s
    shr
    ret

// --- Immediate-operand forms (destacker fuses `ld_* + binop`) ---

fun add_u8_imm(a: u8): u8
    copy_loc a
    ld_u8 7
    add
    ret

fun mul_u128_imm(a: u128): u128
    copy_loc a
    ld_u128 1000
    mul
    ret

fun bit_and_u32_imm(a: u32): u32
    copy_loc a
    ld_u32 4095
    bit_and
    ret

fun shl_u16_imm(a: u16): u16
    copy_loc a
    ld_u8 3
    shl
    ret

fun sub_i32_imm(a: i32): i32
    copy_loc a
    ld_i32 -10
    sub
    ret

// --- Unary negate (signed only) ---

fun negate_i8(a: i8): i8
    copy_loc a
    negate
    ret

fun negate_i64(a: i64): i64
    copy_loc a
    negate
    ret

fun negate_i256(a: i256): i256
    copy_loc a
    negate
    ret
