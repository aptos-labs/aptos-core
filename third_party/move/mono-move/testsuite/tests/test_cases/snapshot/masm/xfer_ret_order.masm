// Regression for return-Xfer-prefix: when an early ret is
// dead-on-arrival (here v0, kept on the stack across `two_args`
// then dropped via `pop`), the rets walk must cascade all later
// rets to Home, even when they're args-walk-eligible. Otherwise
// the rets list becomes `[Home, Xfer(0), Xfer(1)]`, violating the
// "Xfer-bound rets precede Home-bound rets" invariant.

module 0x66::xfer_ret_order

fun three_rets(): (u64, u64, u64)
    ld_u64 1
    ld_u64 2
    ld_u64 3
    ret

fun two_args(_a: u64, _b: u64)
    ret

fun caller()
    call three_rets
    call two_args
    pop
    ret
