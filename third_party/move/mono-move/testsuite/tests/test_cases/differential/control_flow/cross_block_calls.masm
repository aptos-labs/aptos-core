// RUN: publish --print(stackless,micro-ops)
module 0x66::test

fun get_val(): u64
    ld_u64 42
    ret

fun consume(_x: u64): u64
    ld_u64 99
    ret

fun trigger(c: u64): u64
    move_loc c
    ld_u64 0
    gt
    br_true l1
    call get_val
    ret
l1: ld_u64 5
    call consume
    ret

// RUN: execute 0x66::test::trigger --args 0
// CHECK: results: 42

// RUN: execute 0x66::test::trigger --args 1
// CHECK: results: 99

// RUN: execute 0x66::test::trigger --args 100
// CHECK: results: 99
