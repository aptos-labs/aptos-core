// Regression: dead-on-arrival ret must cascade later rets to Home (Xfer-prefix invariant).

// RUN: publish --print(stackless,micro-ops)
module 0x66::xfer_ret_order

fun three_rets(): (u64, u64, u64)
    ld_u64 1
    ld_u64 2
    ld_u64 3
    ret

fun two_args(a: u64, b: u64): u64
    move_loc a
    move_loc b
    add
    ret

public fun caller(): u64
    call three_rets
    call two_args
    pop
    ret

// RUN: execute 0x66::xfer_ret_order::caller
// CHECK: results: 1
