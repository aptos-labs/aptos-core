// RUN: publish --print(stackless,micro-ops)
module 0x66::unpack_partial_xfer_probe

struct Pair has drop+copy
  _1: u64
  _2: u64

fun pair_provider(): Pair
    ld_u64 10
    ld_u64 20
    pack Pair
    ret

fun id(x: u64): u64
    move_loc x
    ret

public fun trigger(): u64
    call pair_provider
    unpack Pair
    call id
    add
    ret

// RUN: execute 0x66::unpack_partial_xfer_probe::trigger
// CHECK: results: 30
