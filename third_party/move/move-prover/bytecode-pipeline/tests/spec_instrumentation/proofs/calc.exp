[variant verification]
fun TestCalc::half($t0|x: u64): u64 {
     var $t1: u64
     var $t2: u64
     var $t3: num
     # VC: calc step at tests/spec_instrumentation/proofs/calc.move:33:9+51
  0: assert Le(Div($t0, 2), $t0)
