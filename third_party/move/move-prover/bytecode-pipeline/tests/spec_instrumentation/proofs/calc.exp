==== spec-instrumenter input specs ====

fun TestCalc::add_three[baseline]
spec {
  requires Le(Add($t0, 3), 18446744073709551615);
  ensures Eq<u64>(result0(), Add($t0, 3));
}

fun TestCalc::add_three[verification]
spec {
  requires Le(Add($t0, 3), 18446744073709551615);
  ensures Eq<u64>(result0(), Add($t0, 3));
}

fun TestCalc::half[baseline]
