============ initial translation from Move ================

[variant baseline]
fun TestCalc::add_three($t0|x: u64): u64 {
     var $t1: u64
     var $t2: u64
     var $t3: u64
     var $t4: u64
     var $t5: u64
     var $t6: u64
     var $t7: u64
  0: $t1 := move($t0)
  1: $t2 := 1
  2: $t3 := +($t1, $t2)
  3: $t4 := 1
  4: $t5 := +($t3, $t4)
  5: $t6 := 1
  6: $t7 := +($t5, $t6)
  7: return $t7
}


[variant baseline]
fun TestCalc::half($t0|x: u64): u64 {
     var $t1: u64
     var $t2: u64
     var $t3: u64
  0: $t1 := move($t0)
  1: $t2 := 2
  2: $t3 := /($t1, $t2)
  3: return $t3
}

============ after pipeline `proofs` ================

[variant baseline]
fun TestCalc::add_three($t0|x: u64): u64 {
     var $t1: u64
     var $t2: u64
     var $t3: num
     var $t4: u64
     var $t5: u64
     var $t6: u64
     var $t7: u64
  0: assume Le(Add($t0, 3), 18446744073709551615)
  1: $t1 := 1
  2: $t2 := +($t0, $t1) on_abort goto 9 with $t3
  3: $t4 := 1
  4: $t5 := +($t2, $t4) on_abort goto 9 with $t3
  5: $t6 := 1
  6: $t7 := +($t5, $t6) on_abort goto 9 with $t3
  7: label L1
  8: return $t7
  9: label L2
 10: abort($t3)
}


