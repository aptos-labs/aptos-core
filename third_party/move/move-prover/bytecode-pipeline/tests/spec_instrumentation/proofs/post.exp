[variant verification]
fun TestPost::max($t0|a: u64, $t1|b: u64): u64 {
     var $t2: bool
     var $t3: u64
  0: $t2 := >=($t0, $t1)
  1: if ($t2) goto 2 else goto 5
  2: label L1
  3: $t3 := move($t0)
  4: goto 7
  5: label L0
  6: $t3 := move($t1)
  7: label L2
     # VC: proof assertion at tests/spec_instrumentation/proofs/post.move:46:18+19
  8: assert Implies(Ge($t0, $t1), Eq<u64>($t3, $t0))
     # VC: proof assertion at tests/spec_instrumentation/proofs/post.move:48:18+19
  9: assert Implies(Not(Ge($t0, $t1)), Eq<u64>($t3, $t1))
     # VC: post-condition does not hold at tests/spec_instrumentation/proofs/post.move:42:9+20
 10: assert Ge($t3, $t0)
     # VC: post-condition does not hold at tests/spec_instrumentation/proofs/post.move:43:9+20
 11: assert Ge($t3, $t1)
 12: return $t3
}


