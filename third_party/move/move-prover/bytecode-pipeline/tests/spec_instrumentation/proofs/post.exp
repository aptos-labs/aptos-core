==== spec-instrumenter input specs ====

fun TestPost::double[baseline]
spec {
  requires Le(Add($t0, $t0), 18446744073709551615);
  ensures Eq<u64>(result0(), Mul(2, $t0));
}

fun TestPost::double[verification]
spec {
  requires Le(Add($t0, $t0), 18446744073709551615);
  ensures Eq<u64>(result0(), Mul(2, $t0));
}

fun TestPost::max[baseline]
spec {
  ensures Ge(result0(), $t0);
  ensures Ge(result0(), $t1);
}

fun TestPost::max[verification]
spec {
  ensures Ge(result0(), $t0);
  ensures Ge(result0(), $t1);
}

fun TestPost::scale[baseline]
spec {
  requires Le(Mul($t0, $t1), 18446744073709551615);
  ensures Eq<u64>(result0(), Mul($t0, $t1));
}

fun TestPost::scale[verification]
spec {
  requires Le(Mul($t0, $t1), 18446744073709551615);
  ensures Eq<u64>(result0(), Mul($t0, $t1));
}
