{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "command -v \"${MOVE_FLOW:-move-flow}\" >/dev/null 2>&1 || echo '[move-flow plugin] move-flow binary not found. Install move-flow or set MOVE_FLOW env var. Please warn the user.'"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "${MOVE_FLOW:-move-flow} hook edit"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "${MOVE_FLOW:-move-flow} hook package-path"
          }
        ]
      }
    ]
  }
}
