[
  {
    "name": "move_package_coverage",
    "description": "Get uncovered source lines for a package",
    "inputSchema": {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "title": "MovePackageCoverageParams",
      "description": "Parameters for `move_package_coverage` tool.",
      "type": "object",
      "properties": {
        "package_path": {
          "description": "Path to the Move package directory.",
          "type": "string"
        },
        "function": {
          "description": "Optional function to scope coverage to, in the format \"module_name::function_name\".\nIf omitted, returns uncovered lines for all functions.",
          "type": "string",
          "nullable": true
        }
      },
      "required": [
        "package_path"
      ]
    },
    "annotations": {
      "readOnlyHint": false,
      "destructiveHint": false
    }
  },
  {
    "name": "move_package_manifest",
    "description": "Get information about the current Move package",
    "inputSchema": {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "title": "MovePackageManifestParams",
      "type": "object",
      "properties": {
        "package_path": {
          "description": "Path to the Move package directory.",
          "type": "string"
        }
      },
      "required": [
        "package_path"
      ]
    },
    "annotations": {
      "readOnlyHint": false,
      "destructiveHint": false
    }
  },
  {
    "name": "move_package_query",
    "description": "Query structural information about a Move package.",
    "inputSchema": {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "title": "MovePackageQueryParams",
      "type": "object",
      "properties": {
        "package_path": {
          "description": "Path to the Move package directory.",
          "type": "string"
        },
        "query": {
          "description": "Query type.",
          "$ref": "#/$defs/QueryType"
        },
        "function": {
          "description": "Function to query (required for \"function_usage\"), in the form \"module_name::function_name\".",
          "type": "string",
          "nullable": true
        }
      },
      "required": [
        "package_path",
        "query"
      ],
      "$defs": {
        "QueryType": {
          "oneOf": [
            {
              "description": "Returns a map from each module to the modules it depends on.",
              "type": "string",
              "const": "dep_graph"
            },
            {
              "description": "Returns a summary of each module's constants, structs, and functions.",
              "type": "string",
              "const": "module_summary"
            },
            {
              "description": "Returns a function-level call graph as a map from each function to the functions it calls.",
              "type": "string",
              "const": "call_graph"
            },
            {
              "description": "Returns direct and transitive calls/uses by a given function.\n\"called\" = direct calls; \"used\" = direct calls + closure captures.",
              "type": "string",
              "const": "function_usage"
            },
            {
              "description": "Returns per-module facts: functions, structs, constants, friends,\nattributes, and source locations.",
              "type": "string",
              "const": "facts"
            }
          ]
        }
      }
    },
    "annotations": {
      "readOnlyHint": true,
      "destructiveHint": false
    }
  },
  {
    "name": "move_package_status",
    "description": "Check a Move package for compilation errors and warnings",
    "inputSchema": {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "title": "MovePackageStatusParams",
      "type": "object",
      "properties": {
        "package_path": {
          "description": "Path to the Move package directory.",
          "type": "string"
        }
      },
      "required": [
        "package_path"
      ]
    },
    "annotations": {
      "readOnlyHint": false,
      "destructiveHint": false
    }
  },
  {
    "name": "move_package_test",
    "description": "Run Move unit tests for a package",
    "inputSchema": {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "title": "MovePackageTestParams",
      "description": "Parameters for `move_package_test` tool.",
      "type": "object",
      "properties": {
        "package_path": {
          "description": "Path to the Move package directory.",
          "type": "string"
        },
        "establish_baseline": {
          "description": "If true, save current coverage as baseline for future comparisons.\nUse this in the first test run before generating new tests.",
          "type": "boolean",
          "default": false
        }
      },
      "required": [
        "package_path"
      ]
    },
    "annotations": {
      "readOnlyHint": false,
      "destructiveHint": false
    }
  },
  {
    "name": "move_package_verify",
    "description": "Verify Move specifications using the Move Prover",
    "inputSchema": {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "title": "MovePackageVerifyParams",
      "type": "object",
      "properties": {
        "package_path": {
          "description": "Path to the Move package directory.",
          "type": "string"
        },
        "filter": {
          "description": "Optional filter: `module_name` or `module_name::function_name`.\nWhen omitted, all target modules are verified.",
          "type": "string",
          "nullable": true
        },
        "exclude": {
          "description": "Optional list of targets to exclude from verification.\nEach entry follows the same format as `filter`: `module_name` or\n`module_name::function_name`. Exclusions take precedence over the filter scope.",
          "type": "array",
          "items": {
            "type": "string"
          },
          "nullable": true
        },
        "timeout": {
          "description": "Solver timeout per verification condition, in seconds. Default: 10. Maximum: 60.",
          "type": "integer",
          "format": "uint",
          "minimum": 0,
          "nullable": true
        },
        "split_vcs_by_assert": {
          "description": "If set, generate an independent verification condition for each\nassertion in a function instead of a single combined condition. Can\nhelp when a function mixes provable-but-hard asserts with asserts\nthat produce counterexamples; useful for diagnosing per-function\ntimeouts.",
          "type": "boolean",
          "nullable": true
        },
        "error_limit": {
          "description": "Maximum number of counterexamples reported per verification\ncondition.",
          "type": "integer",
          "format": "uint",
          "minimum": 0,
          "nullable": true
        }
      },
      "required": [
        "package_path"
      ]
    },
    "annotations": {
      "readOnlyHint": false,
      "destructiveHint": false
    }
  },
  {
    "name": "move_package_wp",
    "description": "Raw WP engine — output requires loop-invariant synthesis and simplification that only the /move-inf skill workflow provides. Do not call directly.",
    "inputSchema": {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "title": "MovePackageSpecInferParams",
      "type": "object",
      "properties": {
        "package_path": {
          "description": "Path to the Move package directory.",
          "type": "string"
        },
        "filter": {
          "description": "Optional filter: `module_name` or `module_name::function_name`.\nWhen omitted, all target modules are inferred.",
          "type": "string",
          "nullable": true
        },
        "spec_output": {
          "description": "Where to write inferred specifications. Defaults to `inline` (inject into\nsource files). Set to `file` to write separate `.spec.move` files instead,\nkeeping original sources untouched.",
          "$ref": "#/$defs/SpecOutput"
        }
      },
      "required": [
        "package_path"
      ],
      "$defs": {
        "SpecOutput": {
          "description": "Controls where inferred specs are written.",
          "oneOf": [
            {
              "description": "Inject inferred specs inline into the original source files (default).",
              "type": "string",
              "const": "inline"
            },
            {
              "description": "Write inferred specs to separate `.spec.move` files alongside the sources,\nleaving the original source files untouched.",
              "type": "string",
              "const": "file"
            }
          ]
        }
      }
    },
    "annotations": {
      "readOnlyHint": false,
      "destructiveHint": true
    }
  },
  {
    "name": "move_replay_transaction",
    "description": "Replay a committed on-chain transaction locally to debug its outcome. Supports optional local Move package overrides.",
    "inputSchema": {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "title": "MoveReplayTransactionParams",
      "type": "object",
      "properties": {
        "txn_id": {
          "description": "The committed transaction version (ledger version) to replay.",
          "type": "integer",
          "format": "uint64",
          "minimum": 0
        },
        "network": {
          "description": "Network: \"mainnet\" | \"testnet\" | \"devnet\" | a REST endpoint URL.",
          "type": "string"
        },
        "local_package_paths": {
          "description": "Optional: paths to local Move packages whose modules override\nthe on-chain versions during replay. Each path must contain Move.toml.",
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": []
        },
        "named_addresses": {
          "description": "Optional: named-address bindings for compiling local packages.\nMaps \"name\" → \"0xADDR\". Only used when local_package_paths is non-empty.",
          "type": "object",
          "additionalProperties": {
            "type": "string"
          },
          "default": {}
        },
        "node_api_key": {
          "description": "Optional: API key sent as `Authorization: Bearer <key>`.",
          "type": "string",
          "default": null,
          "nullable": true
        },
        "trace": {
          "description": "When true, capture a structured trace into the response. Adds\nexactly one `state_view { version, with_overrides }` entry per\nreplay (whichever path the simulator took). Off by default; the\nwrapper costs one extra indirection on every storage read.",
          "type": "boolean",
          "default": false
        },
        "trace_storage_reads": {
          "description": "When true, additionally record one `storage_read` entry per\nstate-view read. Off by default because a single replay typically\nissues hundreds of reads, which crowd out the single `state_view`\nevent. Only consulted when `trace` is true.",
          "type": "boolean",
          "default": false
        },
        "max_trace_events": {
          "description": "Maximum number of trace entries before truncation. Defaults to 500.\nOnly consulted when `trace` is true.",
          "type": "integer",
          "format": "uint",
          "minimum": 0,
          "default": 500
        },
        "redact_storage_keys": {
          "description": "When true, `storage_read` trace entries omit the `Debug`-formatted\n`StateKey`. Defaults to true. Only consulted when both `trace` and\n`trace_storage_reads` are true.",
          "type": "boolean",
          "default": true
        }
      },
      "required": [
        "txn_id",
        "network"
      ]
    },
    "annotations": {
      "readOnlyHint": true,
      "destructiveHint": false
    }
  }
]
